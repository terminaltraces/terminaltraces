// ~/.config/zellij/config.kdl

// ── Theme ──
theme "catppuccin-mocha"

// ── UI ──
default_layout "compact"
pane_frames false
simplified_ui true
rounded_corners true

// ── Behavior ──
copy_on_select true
mouse_mode true
scroll_buffer_size 50000
default_mode "normal"
attach_to_session true

// ── Session resurrection (the ADHD "where was I" safety net) ──
session_serialization true
serialize_pane_viewport true

// ── Clipboard (uncomment yours) ──
// copy_command "wl-copy"          // Wayland (Pop!_OS default)
// copy_command "xclip -selection clipboard"  // X11
// copy_command "pbcopy"           // macOS

// ── Keybinds ──
keybinds {
    // Unbind stuff that fights Claude Code
    unbind "Ctrl t"  // Claude Code uses for todos
    unbind "Ctrl o"  // Claude Code uses for thinking
    unbind "Ctrl g"  // Claude Code uses for nvim edit
    unbind "Ctrl q"  // avoid accidental quit

    shared_except "locked" {
        bind "Alt g" { SwitchToMode "locked"; }
        bind "Alt t" { SwitchToMode "tab"; }
        bind "Alt o" { SwitchToMode "session"; }
        bind "Alt q" { Quit; }

        bind "Alt n" { NewPane; }
        bind "Alt h" { MoveFocus "Left"; }
        bind "Alt j" { MoveFocus "Down"; }
        bind "Alt k" { MoveFocus "Up"; }
        bind "Alt l" { MoveFocus "Right"; }
        bind "Alt d" { NewPane "Down"; }
        bind "Alt r" { NewPane "Right"; }
        bind "Alt f" { ToggleFloatingPanes; }
        bind "Alt w" { TogglePaneFrames; }
        bind "Alt 1" { GoToTab 1; }
        bind "Alt 2" { GoToTab 2; }
        bind "Alt 3" { GoToTab 3; }
        bind "Alt 4" { GoToTab 4; }
    }
}
